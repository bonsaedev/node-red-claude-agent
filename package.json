{
  "name": "@bonsae/node-red-claude",
  "version": "0.0.0",
  "description": "Claude Agent nodes for Node-RED built with @bonsae/nrg",
  "author": "Allan Oricil <allanoricil@duck.com>",
  "license": "BUSL-1.1",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.11.0"
  },
  "keywords": [
    "node-red",
    "nrg"
  ],
  "scripts": {
    "debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode development",
    "dev": "vite --mode development",
    "build:dev": "vite build --mode development",
    "build": "vite build --mode production",
    "validate": "pnpm validate:tsc && pnpm validate:lint && pnpm validate:format",
    "validate:tsc": "tsc -p src/server/tsconfig.json --noEmit && tsc -p tests/server/tsconfig.json --noEmit",
    "validate:lint": "eslint src/",
    "validate:format": "prettier --check \"src/**/*.{ts,vue,json}\"",
    "lint": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\"",
    "test": "pnpm test:server",
    "test:server": "pnpm test:server:unit",
    "test:server:unit": "vitest run --config vitest.server.unit.config.ts",
    "test:server:unit:watch": "vitest --config vitest.server.unit.config.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ],
    "src/**/*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.187"
  },
  "devDependencies": {
    "@bonsae/nrg": "^0.29.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.18",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-red": "^5.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.4",
    "vitest": "^4.1.5",
    "vue": "^3.5.34"
  }
}
